# ingest.py — Load documents from disk, chunk them, embed and store in ChromaDB
# Generated by Ansible — do not edit manually

import os
import argparse
import chromadb
import requests

from config import (
    OLLAMA_URL, EMBED_MODEL,
    CHROMA_HOST, CHROMA_PORT, COLLECTION_NAME,
    CHUNK_SIZE, CHUNK_OVERLAP, SUPPORTED_EXTENSIONS
)

{% raw %}
def get_collection():
    client = chromadb.HttpClient(host=CHROMA_HOST, port=CHROMA_PORT)
    return client.get_or_create_collection(COLLECTION_NAME)


def embed(text: str) -> list:
    """Convert text to a vector using nomic-embed-text via Ollama."""
    response = requests.post(
        f"{OLLAMA_URL}/api/embeddings",
        json={"model": EMBED_MODEL, "prompt": text}
    )
    response.raise_for_status()
    return response.json()["embedding"]


def chunk_text(text: str, chunk_size: int = CHUNK_SIZE, overlap: int = CHUNK_OVERLAP) -> list:
    """Split text into overlapping chunks."""
    chunks = []
    start  = 0
    while start < len(text):
        end = start + chunk_size
        chunks.append(text[start:end])
        start += chunk_size - overlap
    return chunks


def load_files(docs_dir: str) -> list:
    """Walk docs_dir and return (filepath, text) tuples for supported files."""
    files = []
    for root, _, filenames in os.walk(docs_dir):
        for filename in filenames:
            ext = os.path.splitext(filename)[1].lower()
            if ext in SUPPORTED_EXTENSIONS:
                filepath = os.path.join(root, filename)
                with open(filepath, "r", encoding="utf-8", errors="ignore") as f:
                    text = f.read().strip()
                if text:
                    files.append((filepath, text))
    return files


def ingest_file(collection, filepath: str, text: str):
    """Chunk, embed and store a single file into ChromaDB."""
    chunks = chunk_text(text)
    for i, chunk in enumerate(chunks):
        doc_id   = f"{filepath}::chunk{i}"
        vector   = embed(chunk)
        metadata = {
            "source":       filepath,
            "chunk_idx":    i,
            "total_chunks": len(chunks)
        }
        collection.add(
            documents=[chunk],
            embeddings=[vector],
            metadatas=[metadata],
            ids=[doc_id]
        )
    print(f"  ✓ {filepath} → {len(chunks)} chunk(s) ingested")


def ingest_all(docs_dir: str):
    print(f"\n── Loading files from: {docs_dir}\n")
    files = load_files(docs_dir)
    if not files:
        print("No supported files found.")
        return
    collection = get_collection()
    print(f"── Ingesting {len(files)} file(s) into '{COLLECTION_NAME}'\n")
    for filepath, text in files:
        ingest_file(collection, filepath, text)
    print(f"\n── Done. {len(files)} file(s) ingested.\n")


if __name__ == "__main__":
    parser = argparse.ArgumentParser(description="Ingest documents into ChromaDB")
    parser.add_argument("--docs-dir", default="{{ rag_docs_dir }}", help="Path to docs folder")
    args = parser.parse_args()
    ingest_all(args.docs_dir)
