import argparse
import requests
import chromadb

from config import (
    OLLAMA_URL, EMBED_MODEL, LLM_MODEL,
    CHROMA_HOST, CHROMA_PORT, COLLECTION_NAME,
    TOP_N_RESULTS
)

{% raw %}
def get_collection():
    client = chromadb.HttpClient(host=CHROMA_HOST, port=CHROMA_PORT)
    return client.get_or_create_collection(COLLECTION_NAME)


def embed(text: str) -> list:
    response = requests.post(
        f"{OLLAMA_URL}/api/embeddings",
        json={"model": EMBED_MODEL, "prompt": text}
    )
    response.raise_for_status()
    return response.json()["embedding"]


def retrieve(collection, question: str, n: int = TOP_N_RESULTS) -> list:
    """Find the top-n most relevant chunks from ChromaDB."""
    question_vector = embed(question)
    results = collection.query(
        query_embeddings=[question_vector],
        n_results=n,
        include=["documents", "metadatas"]
    )
    chunks = []
    for doc, meta in zip(results["documents"][0], results["metadatas"][0]):
        chunks.append({
            "text":   doc,
            "source": meta.get("source", "unknown")
        })
    return chunks


def generate(question: str, chunks: list) -> str:
    """Assemble context from chunks and send to phi3:mini."""
    context = "\n\n---\n\n".join(chunk["text"] for chunk in chunks)
    prompt = (
        f"You are a helpful assistant for a DevOps home lab.\n"
        f"Use ONLY the context below to answer the question.\n"
        f"If the context doesn't contain the answer, say so clearly.\n\n"
        f"Context:\n{context}\n\n"
        f"Question: {question}"
    )
    response = requests.post(
        f"{OLLAMA_URL}/api/generate",
        json={"model": LLM_MODEL, "prompt": prompt, "stream": False}
    )
    response.raise_for_status()
    return response.json()["response"]


def query(question: str):
    print(f"\n── Question: {question}\n")
    collection = get_collection()
    chunks = retrieve(collection, question)

    print("── Sources retrieved:")
    for i, chunk in enumerate(chunks, 1):
        print(f"   {i}. {chunk['source']}")

    print("\n── Answer:\n")
    answer = generate(question, chunks)
    print(answer)
    print()


if __name__ == "__main__":
    parser = argparse.ArgumentParser(description="Query your RAG pipeline")
    parser.add_argument("question", help='e.g. "How does my Ollama playbook work?"')
    args = parser.parse_args()
    query(args.question)
